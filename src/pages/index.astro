---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/site-chrome/Header.astro";
import Footer from "../components/site-chrome/Footer.astro";
import { getCollection } from "astro:content";

const allPieces = await getCollection('pieces');
const count = (s: string) => allPieces.filter((p: any) => p.data.collection === s).length;
const withCount = (base: string, n: number) => n > 0 ? `${base} · ${n} pieces` : base;

const eth = [
  { slug: 'depths-of-glitch', name: 'Depths of Glitch', note: withCount('generative', count('depths-of-glitch')) },
  { slug: 'glitch-maps',      name: 'Glitch Maps',      note: 'generative · 256.art' },
  { slug: 'murky-depths',     name: 'Murky Depths',     note: 'editions · SuperRare' },
  { slug: 'art-token',        name: 'Art Token',        note: 'bidders editions · Manifold' },
  { slug: 'lurkers',          name: 'Lurkers — Onchain Editions', note: 'editions' },
];
const btc = [
  { slug: 'orange-editions',  name: 'Orange Editions',  note: 'Ordinals · Gamma' },
  { slug: 'orange-haze',      name: 'Orange Haze',      note: '1/1s · Ordinals' },
  { slug: 'the-glitch',       name: 'The Glitch',       note: 'generative · Ordinals' },
  { slug: 'lurkersbtc',       name: 'LurkersBTC',       note: 'PFP · Ordinals' },
  { slug: 'lurker-pepes',     name: 'Lurker Pepes',     note: withCount('hand-drawn · Ordinals', count('lurker-pepes')) },
];
const tez = [
  { slug: 'tezos-editions',   name: 'Tezos Editions',   note: 'The Green Quarter · objkt' },
];
const profiles = [
  { name: 'SuperRare',  href: 'https://superrare.com/sunken0x' },
  { name: 'Manifold',   href: 'https://manifold.xyz/@sunken0x' },
  { name: 'Transient',  href: 'https://www.transient.xyz/@Sunken0x' },
  { name: 'objkt',      href: 'https://objkt.com/users/sunken0x/created' },
  { name: 'X',          href: 'https://x.com/sunken0x' },
  { name: 'Instagram',  href: 'https://instagram.com/sunken0x' },
  { name: 'Medium',     href: 'https://medium.com/@sunken0x' },
];
---
<BaseLayout title="sunken0x">
  <Header />

  <main class="tree">
    <div class="intro">
      <h1>sunken0x</h1>
      <p class="tag">Glitch-native, generative, fully on-chain — across Ethereum, Bitcoin Ordinals & Tezos.</p>
    </div>

    <section class="group">
      <p class="ghead"><span>Ethereum</span></p>
      {eth.map((c) => (
        <a class="row" href={`/${c.slug}`}>
          <span class="rname">{c.name}</span>
          <span class="rnote">{c.note}</span>
          <span class="rarr">→</span>
        </a>
      ))}
    </section>

    <section class="group">
      <p class="ghead"><span>Bitcoin Ordinals</span></p>
      {btc.map((c) => (
        <a class="row" href={`/${c.slug}`}>
          <span class="rname">{c.name}</span>
          <span class="rnote">{c.note}</span>
          <span class="rarr">→</span>
        </a>
      ))}
    </section>

    <section class="group">
      <p class="ghead"><span>Tezos</span></p>
      {tez.map((c) => (
        <a class="row" href={`/${c.slug}`}>
          <span class="rname">{c.name}</span>
          <span class="rnote">{c.note}</span>
          <span class="rarr">→</span>
        </a>
      ))}
    </section>

    <section class="group">
      <p class="ghead"><span>Profiles</span></p>
      {profiles.map((p) => (
        <a class="row prow" href={p.href} target="_blank" rel="noopener">
          <span class="rname">{p.name}</span>
          <span class="rarr">↗</span>
        </a>
      ))}
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .tree { max-width: 640px; margin: 0 auto; padding: 60px 22px 40px; }

  .intro { text-align: center; margin-bottom: 46px; }
  .intro h1 {
    font-family: var(--font-display);
    font-size: clamp(52px, 12vw, 92px);
    color: var(--fg);
    line-height: 1;
    letter-spacing: 0.01em;
    margin: 0;
  }
  .intro .tag {
    max-width: 42ch; margin: 16px auto 0;
    font-size: 13px; line-height: 1.7; color: var(--fg-muted); letter-spacing: 0.02em;
  }

  .group { margin-bottom: 34px; }
  .ghead {
    font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--fg-muted); margin: 0 0 12px; padding-left: 4px;
    display: flex; align-items: center; gap: 12px;
  }
  .ghead::after { content: ''; flex: 1; height: 1px; background: var(--border-faint); }

  .row {
    display: grid;
    grid-template-columns: 1fr auto 22px;
    align-items: baseline;
    gap: 16px;
    padding: 18px 18px;
    margin-bottom: 8px;
    border: 1px solid var(--border-faint);
    text-decoration: none;
    color: var(--fg);
    transition: border-color 0.15s, background 0.15s, transform 0.12s;
  }
  .row:hover { border-color: var(--fg-muted); background: var(--bg-elev); transform: translateY(-2px); }
  .row:hover .rarr { color: var(--fg); }

  .rname { font-family: var(--font-display); font-size: 21px; line-height: 1.1; color: var(--fg); }
  .rnote { font-size: 11px; letter-spacing: 0.06em; color: var(--fg-muted); text-align: right; white-space: nowrap; }
  .rarr { color: var(--fg-faint); text-align: right; transition: color 0.15s; }

  /* profile rows: name + arrow only */
  .prow { grid-template-columns: 1fr 22px; }

  @media (max-width: 520px) {
    .row { grid-template-columns: 1fr 20px; }
    .row .rnote { grid-column: 1 / -1; text-align: left; margin-top: 2px; }
  }
</style>

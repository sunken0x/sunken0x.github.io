---
interface Props {
  src?: string;
  thumbnail?: string;
  title: string;
}
const { src, thumbnail, title } = Astro.props;
---
<div class="piece-embed" data-src={src} data-thumb={thumbnail} data-title={title}>
  {thumbnail && <img class="poster" src={thumbnail} alt={title} loading="lazy" />}
  {!thumbnail && src && <div class="placeholder">{title}</div>}
</div>

<script>
  import { prefersReducedMotion } from '../../lib/reduced-motion';

  const reduced = prefersReducedMotion();
  document.querySelectorAll<HTMLElement>('.piece-embed').forEach((el) => {
    const src = el.dataset.src;
    if (!src || reduced) return;
    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const iframe = document.createElement('iframe');
          iframe.src = src;
          iframe.loading = 'lazy';
          iframe.setAttribute('sandbox', 'allow-scripts');
          iframe.title = el.dataset.title ?? 'piece';
          el.querySelector('.poster, .placeholder')?.remove();
          el.appendChild(iframe);
          observer.disconnect();
        }
      }
    }, { rootMargin: '200px' });
    observer.observe(el);
  });
</script>

<style>
  .piece-embed {
    position: relative;
    aspect-ratio: 1/1;
    background: var(--bg-elev);
    overflow: hidden;
  }
  .piece-embed iframe { width: 100%; height: 100%; border: 0; }
  .poster { width: 100%; height: 100%; object-fit: cover; }
  .placeholder {
    display: grid; place-items: center;
    width: 100%; height: 100%;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-muted);
  }
</style>

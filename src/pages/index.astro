---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/site-chrome/Header.astro";
import Footer from "../components/site-chrome/Footer.astro";
import { getCollection } from "astro:content";

const allPieces = await getCollection('pieces');
const count = (s: string) => allPieces.filter((p: any) => p.data.collection === s).length;
const withCount = (base: string, n: number) => n > 0 ? `${base} · ${n} pieces` : base;

const eth = [
  { slug: 'depths-of-glitch', name: 'Depths of Glitch', note: withCount('generative', count('depths-of-glitch')) },
  { slug: 'glitch-maps',      name: 'Glitch Maps',      note: 'generative · 256.art' },
  { slug: 'murky-depths',     name: 'Murky Depths',     note: 'editions · SuperRare' },
  { slug: 'art-token',        name: 'Art Token',        note: 'bidders editions · Manifold' },
  { slug: 'lurkers',          name: 'Lurkers — Onchain Editions', note: 'editions' },
];
const btc = [
  { slug: 'orange-editions',  name: 'Orange Editions',  note: 'Ordinals · Gamma' },
  { slug: 'orange-haze',      name: 'Orange Haze',      note: '1/1s · Ordinals' },
  { slug: 'the-glitch',       name: 'The Glitch',       note: 'generative · Ordinals' },
  { slug: 'lurkersbtc',       name: 'LurkersBTC',       note: 'PFP · Ordinals' },
  { slug: 'lurker-pepes',     name: 'Lurker Pepes',     note: withCount('hand-drawn · Ordinals', count('lurker-pepes')) },
];
const tez = [
  { slug: 'tezos-editions',   name: 'Tezos Editions',   note: 'The Green Quarter · objkt' },
];
const groups = [
  { label: 'Ethereum', items: eth },
  { label: 'Bitcoin Ordinals', items: btc },
  { label: 'Tezos', items: tez },
];
const profiles = [
  { name: 'SuperRare',  href: 'https://superrare.com/sunken0x' },
  { name: 'Manifold',   href: 'https://manifold.xyz/@sunken0x' },
  { name: 'Transient',  href: 'https://www.transient.xyz/@Sunken0x' },
  { name: 'objkt',      href: 'https://objkt.com/users/sunken0x/created' },
  { name: 'X',          href: 'https://x.com/sunken0x' },
  { name: 'Instagram',  href: 'https://instagram.com/sunken0x' },
  { name: 'Medium',     href: 'https://medium.com/@sunken0x' },
];
---
<BaseLayout title="sunken0x">
  <Header />

  <main class="home">
    <aside class="side">
      <div class="side-in">
        <h1>sunken<span class="hexzero">0</span>x</h1>
        <p class="tag">Glitch-native, generative, fully on-chain — across Ethereum, Bitcoin Ordinals & Tezos.</p>
        <div class="feature">
          <video src="/art/feature.mp4" poster="/art/feature-poster.png" autoplay loop muted playsinline></video>
        </div>
      </div>
    </aside>

    <div class="list">
      {groups.map((g) => (
        <section class="group">
          <p class="ghead"><span>{g.label}</span></p>
          {g.items.map((c) => (
            <a class="row art" href={`/${c.slug}`}>
              <span class="rname">{c.name}</span>
              <span class="rnote">{c.note}</span>
              <span class="rarr">→</span>
            </a>
          ))}
        </section>
      ))}

      <section class="group">
        <p class="ghead"><span>Profiles</span></p>
        {profiles.map((p) => (
          <a class="row prow" href={p.href} target="_blank" rel="noopener">
            <span class="rname">{p.name}</span>
            <span class="rarr">↗</span>
          </a>
        ))}
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const v = document.querySelector('.feature video');
  if (v) { v.muted = true; const go = () => v.play().catch(() => {}); v.addEventListener('canplay', go); go(); }
</script>

<style>
  :root{ --teal:#2ce1f5; }

  .home {
    max-width: 1140px; margin: 0 auto; padding: 44px 24px 40px;
    display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 56px; align-items: start;
  }

  /* ---- left: intro + featured art ---- */
  .side-in { position: sticky; top: 40px; }
  .side h1 {
    font-family: var(--font-display);
    font-size: clamp(46px, 6vw, 76px); color: var(--fg); line-height: 1; margin: 0; letter-spacing: 0.01em;
  }
  .side .tag { max-width: 34ch; margin: 16px 0 26px; font-size: 13px; line-height: 1.7; color: var(--fg-muted); }
  .feature { border: 1px solid var(--border); line-height: 0; background: var(--bg-deep); }
  .feature video { width: 100%; display: block; }

  /* ---- right: the link tree ---- */
  .group { margin-bottom: 30px; }
  .group:last-child { margin-bottom: 0; }
  .ghead {
    font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--fg-muted);
    margin: 0 0 12px; padding-left: 2px; display: flex; align-items: center; gap: 12px;
  }
  .ghead::after { content: ''; flex: 1; height: 1px; background: var(--border-faint); }

  .row {
    display: grid; grid-template-columns: 1fr auto 20px; align-items: baseline; gap: 16px;
    padding: 17px 18px; margin-bottom: 8px;
    border: 1px solid var(--border-faint); text-decoration: none; color: var(--fg);
    transition: border-color 0.15s, background 0.15s, transform 0.12s;
  }
  .row:hover { background: var(--bg-elev); transform: translateY(-2px); }

  .rname { font-family: var(--font-display); font-size: 20px; line-height: 1.1; color: var(--fg); }
  .rnote { font-size: 11px; letter-spacing: 0.05em; color: var(--fg-muted); text-align: right; white-space: nowrap; }
  .rarr { text-align: right; transition: color 0.15s; }

  /* teal accent for the ART rows (collections) */
  .row.art { border-left: 2px solid var(--teal); }
  .row.art .rarr { color: var(--teal); }
  .row.art:hover { border-color: var(--teal); }

  /* profiles: muted, name + arrow only */
  .prow { grid-template-columns: 1fr 20px; }
  .prow .rarr { color: var(--fg-faint); }
  .prow:hover { border-color: var(--fg-muted); }
  .prow:hover .rarr { color: var(--fg); }

  @media (max-width: 820px) {
    .home { grid-template-columns: 1fr; gap: 34px; }
    .side-in { position: static; }
    .feature { max-width: 460px; }
  }
  @media (max-width: 520px) {
    .row { grid-template-columns: 1fr 18px; }
    .row .rnote { grid-column: 1 / -1; text-align: left; margin-top: 2px; }
  }
</style>

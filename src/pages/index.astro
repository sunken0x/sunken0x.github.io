---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/site-chrome/Header.astro";
import Footer from "../components/site-chrome/Footer.astro";
import { getCollection } from "astro:content";

const featured = (await getCollection('pieces', (p: any) => p.data.featured))
  .sort((a: any, b: any) => (a.data.featured_order ?? 999) - (b.data.featured_order ?? 999))
  .slice(0, 6);

const allPieces = await getCollection('pieces');
const surfaceSamples = allPieces.slice(0, 6);
const showing = featured.length > 0 ? featured : surfaceSamples;

const count = (s: string) => allPieces.filter((p: any) => p.data.collection === s).length;

const collections = [
  { slug: 'depths-of-glitch', name: 'Depths of Glitch',          chain: 'Ethereum', note: 'generative' },
  { slug: 'glitch-maps',      name: 'Glitch Maps',               chain: 'Ethereum', note: 'generative · 256.art' },
  { slug: 'murky-depths',     name: 'Murky Depths',              chain: 'Ethereum', note: 'editions · SuperRare' },
  { slug: 'art-token',        name: 'Art Token',                 chain: 'Ethereum', note: 'bidders editions · Manifold' },
  { slug: 'lurkers',          name: 'Lurkers — Onchain Editions', chain: 'Ethereum', note: 'editions' },
  { slug: 'orange-editions',  name: 'Orange Editions',           chain: 'Bitcoin',  note: 'Ordinals · Gamma' },
  { slug: 'orange-haze',      name: 'Orange Haze',               chain: 'Bitcoin',  note: '1/1s · Ordinals' },
  { slug: 'the-glitch',       name: 'The Glitch',                chain: 'Bitcoin',  note: 'generative · Ordinals' },
  { slug: 'lurkersbtc',       name: 'LurkersBTC',                chain: 'Bitcoin',  note: 'PFP · Ordinals' },
  { slug: 'lurker-pepes',     name: 'Lurker Pepes',              chain: 'Bitcoin',  note: 'hand-drawn · Ordinals' },
  { slug: 'tezos-editions',   name: 'Tezos Editions',            chain: 'Tezos',    note: 'objkt' },
];
---
<BaseLayout title="sunken0x">
  <Header />

  <!-- hero -->
  <section class="hero">
    <div class="readout">GLITCH · GENERATIVE · ON-CHAIN</div>
    <h1>
      <span class="line-1">Glitch, generative,</span>
      <span class="line-2">fully on-chain.</span>
    </h1>

    <p class="lede">
      The work of <span class="attrib">sunken0x</span> — glitch-native and generative,
      across Ethereum, Bitcoin Ordinals, and Tezos.
    </p>

    <div class="hero-actions">
      <a href="/works" class="cta" data-hover>
        <span class="cta-label">View works →</span>
        <span class="cta-sub">{allPieces.length} pieces · {collections.length} collections</span>
      </a>
    </div>
  </section>

  <!-- selected -->
  <section class="deck">
    <header class="deck-head">
      <div>
        <p class="readout">Selected</p>
        <h2>Recent work</h2>
      </div>
      <a href="/works" class="deck-link" data-hover>all works <span class="arr">→</span></a>
    </header>

    <div class="catch-grid">
      {showing.map((p: any, i: number) => {
        const href = p.data.collection === 'depths-of-glitch'
          ? `/depths-of-glitch/${p.data.slug}`
          : `/${p.data.collection}`;
        return (
          <a href={href} class="catch" data-hover>
            <div class="tag-top">
              <span>{p.data.chain}</span>
              <span>№ {String(i + 1).padStart(2, '0')}</span>
            </div>
            <div class="catch-embed">
              {p.data.live_source
                ? <iframe src={p.data.live_source} loading="lazy" sandbox="allow-scripts" title={p.data.title}></iframe>
                : <div class="catch-blank">—</div>
              }
            </div>
            <div class="tag-body">
              <h3>{p.data.title}</h3>
              <p class="sub">{p.data.collection.replaceAll('-', ' ')}</p>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- collections -->
  <section class="index">
    <div class="index-head">
      <p class="readout">Collections</p>
    </div>

    <ul class="index-list">
      {collections.map((c) => (
        <li>
          <a href={`/${c.slug}`} data-hover>
            <span class="c-chain">{c.chain}</span>
            <span class="c-name">{c.name}</span>
            <span class="c-note">{c.note}</span>
            <span class="c-count">{count(c.slug)} <em>pcs</em></span>
            <span class="c-arr">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <Footer />
</BaseLayout>

<style>
  .hero {
    padding: 70px 40px 90px;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  h1 {
    margin: 6px 0 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(48px, 9vw, 132px);
    color: var(--fg);
    line-height: 0.94;
    letter-spacing: -0.03em;
  }
  .line-1 { display: block; color: var(--fg-muted); }
  .line-2 { display: block; color: var(--fg); }

  .lede {
    max-width: 54ch;
    font-size: 17px;
    line-height: 1.7;
    color: var(--fg-warm);
    margin: 10px 0 0;
  }
  .attrib {
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg);
    background: var(--bg-elev);
    padding: 2px 8px;
    border: 1px solid var(--border);
    margin: 0 2px;
  }

  .hero-actions { margin-top: 22px; }
  .cta {
    display: inline-block;
    padding: 16px 24px;
    border: 1px solid var(--fg);
    color: var(--fg);
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .cta:hover { background: var(--fg); color: var(--bg-sig); }
  .cta:hover .cta-sub { color: var(--bg-sig); }
  .cta-label { display: block; font-size: 15px; letter-spacing: 0.06em; }
  .cta-sub {
    display: block;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-top: 6px;
  }

  /* selected */
  .deck { padding: 40px 40px 60px; max-width: 1400px; margin: 0 auto; }
  .deck-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    margin-bottom: 34px;
    border-top: 1px solid var(--border-faint);
    padding-top: 26px;
  }
  .deck-head h2 { font-family: var(--font-display); font-weight: 600; font-size: clamp(30px, 4vw, 52px); margin: 8px 0 0; color: var(--fg); letter-spacing: -0.02em; }
  .deck-link {
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--fg-muted); text-decoration: none; white-space: nowrap;
    padding-bottom: 6px; border-bottom: 1px solid var(--border);
  }
  .deck-link:hover { color: var(--fg); border-color: var(--fg); }
  .deck-link .arr { margin-left: 6px; }

  .catch-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
  .catch { text-decoration: none; color: var(--fg); border: 1px solid var(--border-faint); transition: transform 0.15s, border-color 0.15s; }
  .catch:hover { transform: translateY(-4px); border-color: var(--fg-muted); }
  .tag-top {
    display: flex; justify-content: space-between;
    padding: 10px 12px;
    font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--fg-muted);
  }
  .catch-embed { position: relative; aspect-ratio: 1/1; overflow: hidden; background: var(--bg-deep); border-top: 1px solid var(--border-faint); border-bottom: 1px solid var(--border-faint); }
  .catch-embed iframe { width: 100%; height: 100%; border: 0; pointer-events: none; }
  .catch-blank { display: grid; place-items: center; width: 100%; height: 100%; color: var(--fg-faint); }
  .tag-body { padding: 12px; }
  .tag-body h3 { margin: 0; font-size: 15px; color: var(--fg); font-weight: 600; }
  .sub { margin: 4px 0 0; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fg-muted); }

  /* collections */
  .index { padding: 40px 40px 70px; max-width: 1400px; margin: 0 auto; }
  .index-head { border-top: 1px solid var(--border-faint); padding-top: 26px; margin-bottom: 6px; }
  .index-list { list-style: none; padding: 0; margin: 0; }
  .index-list li { border-bottom: 1px solid var(--border-faint); }
  .index-list a {
    display: grid;
    grid-template-columns: 110px 1.4fr 1.4fr auto 30px;
    align-items: baseline;
    gap: 24px;
    padding: 22px 4px;
    text-decoration: none;
    color: var(--fg);
    transition: background 0.2s, padding 0.2s;
  }
  .index-list a:hover { background: var(--bg-elev); padding-left: 18px; }
  .index-list a:hover .c-arr { color: var(--fg); transform: translateX(4px); }
  .c-chain { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--fg-muted); }
  .c-name { font-family: var(--font-display); font-weight: 500; font-size: clamp(20px, 2.4vw, 32px); line-height: 1.05; color: var(--fg); }
  .c-note { font-size: 12px; letter-spacing: 0.06em; color: var(--fg-muted); }
  .c-count { font-size: 12px; color: var(--fg-warm); }
  .c-count em { font-style: normal; color: var(--fg-faint); font-size: 10px; letter-spacing: 0.16em; }
  .c-arr { color: var(--fg-faint); text-align: right; transition: color 0.2s, transform 0.2s; }

  @media (max-width: 860px) {
    .hero { padding: 30px 22px 50px; }
    .deck, .index { padding-left: 22px; padding-right: 22px; }
    .deck-head { flex-direction: column; align-items: flex-start; }
    .index-list a { grid-template-columns: 80px 1fr; gap: 8px; }
    .index-list .c-note, .index-list .c-count, .index-list .c-arr { grid-column: 1 / -1; padding-left: 88px; margin-top: -6px; }
  }
</style>

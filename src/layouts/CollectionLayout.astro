---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/site-chrome/Header.astro";
import Footer from "../components/site-chrome/Footer.astro";
import PieceEmbed from "../components/shared/PieceEmbed.astro";
import BuyLink from "../components/shared/BuyLink.astro";
import ChainBadge from "../components/shared/ChainBadge.astro";
import { getCollection } from "astro:content";

interface Props {
  title: string;
  slug: 'glitch-maps' | 'murky-depths' | 'lurkers' | 'orange-editions' | 'art-token' | 'tezos-editions' | 'orange-haze' | 'the-glitch' | 'lurkersbtc' | 'lurker-pepes';
  intro?: string;
  accent?: 'default' | 'orange';
  depth?: string;
  station?: string;
  marketplace_url?: string;
  marketplace_label?: string;
  secondary_url?: string;
  secondary_label?: string;
}
const { title, slug, intro, accent = 'default', depth = '−0300m', station = '03', marketplace_url, marketplace_label, secondary_url, secondary_label } = Astro.props;
const pieces = (await getCollection('pieces', (p: any) => p.data.collection === slug))
  .sort((a: any, b: any) => (a.data.date > b.data.date ? -1 : 1));
---
<BaseLayout title={`${title} — sunken0x`}>
  <Header />
  <main class={`coll ${accent}`}>

    <section class="coll-hero">
      <p class="readout sink sink-1">Station {station} · {title.toLowerCase()}</p>
      <h1 class="display display-dense sink sink-2">{title}</h1>
      {intro && <p class="coll-intro sink sink-3"><em>{intro}</em></p>}

      {marketplace_url && (
        <p class="coll-market sink sink-3">
          <a href={marketplace_url} target="_blank" rel="noopener">{marketplace_label ?? 'View collection'} →</a>
          {secondary_url && (
            <a class="coll-market-secondary" href={secondary_url} target="_blank" rel="noopener">{secondary_label ?? 'Full profile'} →</a>
          )}
        </p>
      )}

      <div class="depth-marker sink sink-4">
        <span class="tick">{depth}</span>
        <div class="rule"></div>
        <span>{pieces.length} specimen{pieces.length === 1 ? '' : 's'}</span>
      </div>
    </section>

    {pieces.length === 0
      ? (
        <div class="coll-empty">
          <p class="display display-loose">Empty net.</p>
          <p>This station is being catalogued. Return soon, or follow the departures in the log book below.</p>
        </div>
      )
      : (
        <div class="coll-grid">
          {pieces.map((p: any, i: number) => (
            <article class="specimen" data-hover>
              <div class="tag-top">
                <span>№ {String(i + 1).padStart(3, '0')}</span>
                <ChainBadge chain={p.data.chain} />
              </div>
              <div class="spec-embed">
                <PieceEmbed src={p.data.live_source} thumbnail={p.data.thumbnail} title={p.data.title} />
              </div>
              <div class="tag-body">
                <h3>{p.data.title}</h3>
                <p class="latin">{p.data.technique.join(' · ')}</p>
                {p.data.notes && <p class="notes">{p.data.notes}</p>}
                <div class="spec-actions">
                  <BuyLink buy_enabled={p.data.buy_enabled} marketplace_url={p.data.marketplace_url} />
                </div>
              </div>
            </article>
          ))}
        </div>
      )
    }

  </main>
  <Footer />
</BaseLayout>

<style>
  .coll { padding: 40px 40px 60px; max-width: 1400px; margin: 0 auto; }
  .coll-hero { padding: 40px 0 40px; }
  .coll-hero h1 {
    margin: 10px 0 20px;
    font-size: clamp(56px, 8vw, 140px);
    color: var(--fg);
  }
  .coll-intro {
    max-width: 56ch;
    font-size: 19px;
    color: var(--fg-warm);
    margin: 0 0 28px;
  }
  .coll.orange h1 { color: var(--rust); }
  .coll-market { margin: 0 0 28px; }
  .coll-market a {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    padding: 6px 10px;
    text-decoration: none;
    border: 1px solid var(--glitch-mag);
    color: var(--glitch-mag);
  }
  .coll-market a:hover { background: var(--glitch-mag); color: var(--bg); }
  .coll-market a.coll-market-secondary {
    margin-left: 10px;
    border-color: var(--border);
    color: var(--fg-muted);
  }
  .coll-market a.coll-market-secondary:hover { background: var(--fg-muted); color: var(--bg); }
  .coll-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 30px;
    margin-top: 28px;
  }
  .spec-embed { border-top: 1px solid var(--border-faint); border-bottom: 1px solid var(--border-faint); }
  .spec-actions { margin-top: 14px; }

  .coll-empty {
    text-align: center;
    padding: 80px 20px;
    color: var(--fg-muted);
  }
  .coll-empty .display { font-size: 54px; color: var(--fg); margin-bottom: 12px; }

  @media (max-width: 860px) {
    .coll { padding: 20px 22px 40px; }
  }
</style>
